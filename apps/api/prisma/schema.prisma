// Schema da Fase 0 — a fundação. Catálogo, pedidos e estoque chegam na Fase 1.
//
// Convenções (docs/arquitetura.md §7):
//   - PK cuid(): ordenável no tempo, não vaza contagem de pedidos, seguro em URL
//   - Dinheiro em Int (centavos). Peso em gramas. Dimensão em milímetros.
//   - onDelete: Restrict por padrão. Cascade só de pai para filho do mesmo agregado.
//   - storeId nas raízes de agregado + onde a unicidade precisa ser por loja.
//
// Enums duplicam packages/shared/src/constants/enums.ts porque o browser não pode
// importar @prisma/client. test/enum-drift.test.ts impede a divergência silenciosa.

generator client {
  provider = "prisma-client-js"
}

// As URLs de conexão vivem em prisma.config.ts (o Prisma 6 as removeu daqui).
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// Movimento de estoque. O sinal fica em `quantity`, não no tipo.
enum MovementType {
  PURCHASE // + fornecedor, produção, estoque inicial (admin)
  SALE // − venda confirmada (sistema, via webhook)
  RETURN // + devolução reintegrada (admin)
  CANCELLATION // + pedido pago cancelado (sistema)
  ADJUSTMENT // ± quebra, perda, correção (admin, motivo obrigatório)
  COUNT // ± inventário físico, grava a diferença (admin)
}

/// Dois eixos ortogonais em vez de um enum cartesiano (PAID_SHIPPED, ...):
/// pagamento e logística evoluem independentemente. Só o webhook do Stripe muda
/// o pagamento (Fase 1.13).
enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PICKING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  RETURNED
}

/// Método com que o cliente pagou. BOLETO existe no enum (espelha PAYMENT_METHODS
/// em constants, guardado pelo drift), mas só CARD/PIX são habilitados por ora.
enum PaymentMethod {
  CARD
  PIX
  BOLETO
}

/// Uma única linha na v1. Toda query filtra por storeId via getActiveStoreId().
/// Sem planId/status/trialEndsAt/themeId: campo morto confunde quem lê o schema.
/// Eles nascem na Fase 4, junto com a funcionalidade.
model Store {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  domain   String  @unique
  email    String
  phone    String?
  document String?

  /// Endereço de origem do frete. JSON porque é lido inteiro e nunca filtrado.
  addressJson Json?

  currency String @default("BRL")
  timezone String @default("America/Sao_Paulo")
  locale   String @default("pt-BR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  customers  Customer[]
  settings   Setting[]
  auditLogs  AuditLog[]
  uploads    Upload[]
  categories Category[]
  products   Product[]
  variants   ProductVariant[]
  movements  InventoryMovement[]
  carts      Cart[]
  orders     Order[]
  newsletterSubscribers NewsletterSubscriber[]
}

/// Staff. Cliente da loja é Customer (Fase 1) — tabela separada de propósito:
/// ciclos de vida distintos, e na Fase 4 divergem ainda mais.
model User {
  id           String    @id @default(cuid())
  storeId      String
  name         String
  email        String
  passwordHash String
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  uploads       Upload[]
  movements     InventoryMovement[]

  /// Hoje redundante (uma loja). Na Fase 4 é o que impede colisão entre lojas.
  @@unique([storeId, email])
  @@index([storeId])
}

/// Guardamos o HASH, não o token: um dump do banco não dá sessões ao atacante.
/// replacedById forma a cadeia de rotação — ver detecção de reúso em auth/service.ts.
model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  /// Exatamente um de userId/customerId preenchido (CHECK na migration). Staff e
  /// cliente compartilham a tabela mas nunca a mesma sessão.
  userId     String?
  customerId String?
  expiresAt  DateTime
  revokedAt  DateTime?

  /// Aponta para o token que substituiu este. Presença + revokedAt = rotacionado.
  replacedById String?       @unique
  replacedBy   RefreshToken? @relation("TokenChain", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces     RefreshToken? @relation("TokenChain")

  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([customerId])
  @@index([expiresAt])
}

/// Cliente da loja. Tabela SEPARADA de User (staff): ciclos de vida distintos —
/// o cliente se auto-cadastra, tem CPF, endereços e histórico de compra; o staff
/// é criado por convite e auditado. `passwordHash` é opcional: guest checkout
/// cria o cliente sem senha, e ele pode definir uma depois e assumir o histórico.
model Customer {
  id               String    @id @default(cuid())
  storeId          String
  name             String
  email            String
  passwordHash     String?
  phone            String?
  document         String? // CPF/CNPJ
  documentType     String?
  birthDate        DateTime?
  emailVerifiedAt  DateTime?
  acceptsMarketing Boolean   @default(false)
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  carts         Cart[]
  addresses     Address[]
  orders        Order[]

  @@unique([storeId, email])
  @@index([storeId])
}

/// Endereço do cliente (entrega/cobrança). Filho de Customer — a posse é sempre
/// pelo customerId no service (nunca só pela rota; requireAuth não impede IDOR).
/// zipCode é normalizado: 8 dígitos, sem hífen (a máscara é da UI, o dado é limpo).
/// Ao virar pedido, o endereço é COPIADO (snapshot em Order.shippingAddressJson):
/// mudar o endereço depois não altera o histórico de entregas.
model Address {
  id         String  @id @default(cuid())
  customerId String
  label      String? // "Casa", "Trabalho"
  recipient  String // quem recebe (pode não ser o titular da conta)
  zipCode    String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String // UF, 2 letras
  country    String  @default("BR")
  isDefault  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Carrinho (Fase 1.8) ──────────────────────────────────────────────────────
//
// O carrinho NÃO vira pedido: o checkout LÊ o carrinho e CONSTRÓI um pedido novo,
// recalculando tudo do banco. Preço de item no carrinho é sempre AO VIVO (o
// cliente vê o preço atual da variante); preço no pedido é congelado.
//
// Por cliente OU por sessão anônima (sessionToken em cookie). Ao logar, o
// carrinho anônimo é mesclado no do cliente.

model Cart {
  id           String  @id @default(cuid())
  storeId      String
  customerId   String?
  /// Anônimo: token opaco em cookie. Exatamente um de customerId/sessionToken.
  sessionToken String? @unique
  couponId     String?

  /// Snapshot da cotação de frete ESCOLHIDA (serviço, transportadora, preço,
  /// prazo, id do Melhor Envio). Sempre revalidado antes de cobrar (Fase 1.10).
  shippingQuoteJson Json?

  /// Carrinho abandonado é varrido por job. Renovado a cada interação.
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@index([storeId, customerId])
  @@index([expiresAt])
}

/// Item do carrinho. SEM preço: o preço é sempre lido da variante, ao vivo.
model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int

  createdAt DateTime @default(now())

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  /// Uma linha por variante no carrinho: adicionar de novo incrementa a qtd.
  @@unique([cartId, variantId])
}

/// Chave-valor tipado com Zod por chave (shared/settings). Alternativa rejeitada:
/// tabela larga com uma coluna por config — cada nova config viraria migração.
model Setting {
  id        String   @id @default(cuid())
  storeId   String
  key       String
  valueJson Json
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, key])
}

/// Nasce junto com o primeiro CRUD, não no endurecimento: auditoria adicionada
/// depois não é retroativa — os meses sem ela são um buraco permanente.
model AuditLog {
  id          String   @id @default(cuid())
  storeId     String
  userId      String?
  /// Vocabulário de EVENTS em shared/constants: "product.updated".
  action      String
  entityType  String
  entityId    String
  /// Diff { campo: { from, to } }. Sem valores sensíveis — o redator é no service.
  changesJson Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

// ─── Catálogo (Fase 1.4) ──────────────────────────────────────────────────────
//
// O Product é MARKETING (o que é, como se chama, como aparece no Google).
// A ProductVariant é COMÉRCIO (o que se envia, quanto custa, quanto pesa).
// Todo produto tem no mínimo UMA variante — mesmo sem opções, uma "Default".
// Preço, SKU, peso e dimensões vivem SEMPRE na variante, sem exceção: é o que
// elimina o `if (hasVariants)` espalhado por carrinho, pedido, frete e estoque.

/// Produto. `deletedAt` para soft delete: um produto com pedidos históricos não
/// pode sumir, senão o pedido antigo perde a referência.
model Product {
  id               String        @id @default(cuid())
  storeId          String
  name             String
  slug             String
  description      String?
  shortDescription String?
  status           ProductStatus @default(DRAFT)
  brand            String?
  tags             String[]      @default([])
  seoTitle         String?
  seoDescription   String?
  publishedAt      DateTime?
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categories ProductCategory[]
  images     ProductImage[]
  options    ProductOption[]
  variants   ProductVariant[]
  views      ProductView[]

  @@unique([storeId, slug])
  @@index([storeId, status])
}

/// Contador de visitas por produto, agregado por DIA (rollup). Não guardamos cada
/// visita — só o total do dia —, porque "mais visitados" só precisa da soma. A
/// loja dispara um POST leve ao abrir a página do produto; o upsert incrementa o
/// dia corrente. Barato de gravar, barato de somar num range.
model ProductView {
  id        String   @id @default(cuid())
  storeId   String
  productId String
  date      DateTime @db.Date
  count     Int      @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId, date])
  @@index([storeId, date])
}

/// N:N produto ↔ categoria. Um vaso pode estar em "Vasos" e em "Novidades".
model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

/// Imagem do produto. `variantId` opcional: a foto pode trocar ao selecionar a cor.
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  uploadId  String
  alt       String?
  position  Int     @default(0)
  variantId String?

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  upload  Upload          @relation(fields: [uploadId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId, position])
}

/// Opção de variação: "Cor", "Tamanho".
model ProductOption {
  id        String @id @default(cuid())
  productId String
  name      String
  position  Int    @default(0)

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]

  @@unique([productId, name])
}

/// Valor de uma opção: "Verde", "Grande".
model ProductOptionValue {
  id       String @id @default(cuid())
  optionId String
  value    String
  position Int    @default(0)

  option   ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants VariantOptionValue[]

  @@unique([optionId, value])
}

/// A variante — o produto vendável de verdade. storeId denormalizado (filho do
/// Product) por UM motivo: `sku` precisa ser único POR LOJA, e a constraint
/// exige a coluna aqui. É a única razão legítima para denormalizar.
model ProductVariant {
  id             String  @id @default(cuid())
  storeId        String
  productId      String
  sku            String
  barcode        String?
  price          Int // centavos
  compareAtPrice Int? // preço "de" riscado
  costPrice      Int? // custo interno, alimenta a margem
  weight         Int     @default(0) // gramas — sem isto não há cotação de frete
  length         Int     @default(0) // milímetros
  width          Int     @default(0)
  height         Int     @default(0)
  position       Int     @default(0)
  isActive       Boolean @default(true)
  imageId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues VariantOptionValue[]
  images       ProductImage[]
  level        InventoryLevel?
  movements    InventoryMovement[]
  reservations InventoryReservation[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@unique([storeId, sku])
  @@index([productId])
}

/// Define a combinação: esta variante = Verde + Grande.
model VariantOptionValue {
  variantId     String
  optionValueId String

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([optionValueId])
}

// ─── Estoque (Fase 1.5) ───────────────────────────────────────────────────────
//
// Livro-razão append-only (InventoryMovement) + projeção materializada
// (InventoryLevel). O movimento registra FATOS FÍSICOS; a projeção é o cache da
// verdade, reconstruível a qualquer momento por SUM(quantity). Reserva NÃO é
// movimento: é intenção (o produto continua na prateleira até a venda).

/// Projeção materializada. `available = onHand - reserved`. NÃO é a verdade —
/// é o cache dela. Reconstruível de InventoryMovement.
model InventoryLevel {
  id        String   @id @default(cuid())
  variantId String   @unique
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  updatedAt DateTime @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

/// APPEND-ONLY. Nunca UPDATE, nunca DELETE. Errou? Lance um movimento contrário.
/// `quantity` tem sinal (PURCHASE +, SALE −). `reference` liga ao pedido: "order:xyz".
model InventoryMovement {
  id        String       @id @default(cuid())
  storeId   String
  variantId String
  type      MovementType
  quantity  Int
  reason    String?
  reference String?
  userId    String?
  createdAt DateTime     @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user    User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([variantId, createdAt])
  @@index([storeId, createdAt])
  @@index([reference])
}

/// Reserva de estoque durante o checkout. Intenção, não fato: `reserved += qty`
/// no InventoryLevel, mas NENHUM movimento. Pagou → vira SALE e libera a reserva.
/// Expirou/falhou → só libera. orderId sem FK ainda: Order nasce na Fase 1.11.
model InventoryReservation {
  id         String    @id @default(cuid())
  variantId  String
  orderId    String
  quantity   Int
  expiresAt  DateTime
  releasedAt DateTime?
  createdAt  DateTime  @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([expiresAt, releasedAt])
  @@index([orderId])
}

/// Árvore de categorias por ADJACENCY LIST (só `parentId`), não nested set nem
/// closure table. Com ~50 categorias e 2-3 níveis, uma query carrega tudo e a
/// árvore se monta em memória em microssegundos. Nested set otimizaria uma
/// leitura que já é instantânea e complicaria toda escrita.
model Category {
  id          String  @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String?
  imageId     String?

  /// Auto-relação. onDelete: Restrict — apagar uma categoria com filhas deve
  /// falhar alto, não deixar filhas órfãs apontando para o vazio.
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")

  /// Ordem de exibição entre irmãs. O front ordena por isto, não por nome.
  position Int     @default(0)
  isActive Boolean @default(true)

  seoTitle       String?
  seoDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  image    Upload?           @relation(fields: [imageId], references: [id], onDelete: SetNull)
  products ProductCategory[]

  /// Slug único POR LOJA, não global: é o que a Fase 4 vai precisar, e criar o
  /// índice composto agora evita reescrevê-lo em produção depois.
  @@unique([storeId, slug])
  @@index([storeId, parentId])
}

/// Contador do rate limit. Vive no BANCO, não em memória: com `pm2 cluster` de 4
/// instâncias, um contador em memória por processo faz o limite real virar 4x o
/// configurado — e quem faz brute force cai na instância que ainda tem folga.
///
/// Sem storeId de propósito: a chave já embute o escopo (ip, email), e na Fase 4
/// um atacante não deve ganhar N tentativas por loja existente.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  /// Varrido por job; sem isto a tabela cresce para sempre.
  @@index([expiresAt])
}

/// Guarda `key`, NÃO `url`: a URL é derivada por getPublicUrl(key).
/// Persistir a URL completa amarraria os dados ao provedor de hoje — trocar de
/// storage viraria UPDATE em toda a tabela.
model Upload {
  id       String  @id @default(cuid())
  storeId  String
  key      String  @unique
  filename String
  mimeType String
  size     Int
  width    Int?
  height   Int?
  folder   String?
  userId   String?

  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Lados inversos. onDelete: Restrict no ProductImage.upload impede apagar um
  /// Upload que ainda ilustra um produto — a imagem quebrada apareceria na loja.
  categories    Category[]
  productImages ProductImage[]

  @@index([storeId, createdAt])
}

/// Pedido. Nasce do checkout com paymentStatus PENDING; o pagamento (Fase 1.12) e
/// a expedição evoluem em eixos separados. Endereço e método de frete são SNAPSHOT
/// (Json): um pedido é documento histórico, não uma view do catálogo/cadastro atual.
model Order {
  id         String  @id @default(cuid())
  storeId    String
  /// Sequencial por loja, legível ("#1042"). Único via @@unique.
  number     Int
  customerId String
  email      String
  phone      String?

  paymentStatus     PaymentStatus     @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  canceledAt        DateTime?
  cancelReason      String?

  /// Tudo em centavos. Recalculado no backend, do banco — o front nunca decide.
  subtotal      Int
  discountTotal Int @default(0)
  shippingTotal Int
  total         Int

  couponId           String?
  couponCodeSnapshot String?

  shippingAddressJson Json
  billingAddressJson  Json?
  /// { carrier, service, serviceId, price, deliveryDays } da opção escolhida.
  shippingMethodJson  Json

  customerNote String?
  internalNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]
  events   OrderEvent[]
  payments Payment[]

  @@unique([storeId, number])
  @@index([storeId, paymentStatus])
  @@index([storeId, fulfillmentStatus])
  @@index([storeId, createdAt])
  @@index([customerId])
}

/// Item do pedido: TUDO é snapshot. Apagar a variante em 2027 não muda o pedido de
/// 2026. variantId com SetNull mantém a linha viva mesmo sem a variante atual.
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  variantId   String?
  productName String
  variantName String
  sku         String
  unitPrice   Int
  quantity    Int
  totalPrice  Int
  weight      Int
  imageUrl    String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

/// Timeline do pedido (o admin exibe, o suporte usa). `type` usa o vocabulário de
/// eventos (order.paid, order.shipped...), o mesmo do AuditLog e da fila.
model OrderEvent {
  id           String   @id @default(cuid())
  orderId      String
  type         String
  description  String
  metadataJson Json?
  userId       String?
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

/// Tentativa de pagamento de um pedido, espelhando um PaymentIntent do Stripe.
/// O status é escrito SÓ pelo webhook (regra de ouro): nasce PROCESSING quando o
/// PI é criado, vira PAID/FAILED pelo evento. `amount` em centavos, do total do
/// pedido — o front nunca decide. Um pedido pode ter mais de uma tentativa.
model Payment {
  id                    String         @id @default(cuid())
  storeId               String
  orderId               String
  /// Chave natural do Stripe: garante idempotência e liga o webhook ao pagamento.
  stripePaymentIntentId String         @unique
  stripeChargeId        String?
  status                PaymentStatus  @default(PROCESSING)
  method                PaymentMethod?
  amount                Int
  currency              String         @default("brl")
  paidAt                DateTime?
  /// Soma dos reembolsos já confirmados pelo Stripe, em centavos. Responde
  /// "total ou parcial?" sem tabela Refund; o histórico por reembolso vive no
  /// OrderEvent. Escrito SÓ pelo webhook charge.refunded, como o status.
  refundedAmount        Int            @default(0)
  refundedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

/// Livro de eventos recebidos do Stripe. A PK é o `event.id` do Stripe: inserir o
/// mesmo evento duas vezes bate no unique e é ignorado — é o que torna o webhook
/// idempotente (o Stripe reentrega em caso de timeout/erro). `processedAt` marca
/// que o efeito colateral já rodou.
model StripeEvent {
  id          String    @id
  type        String
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  payloadJson Json?
}

/// Inscrito na newsletter (formulário público da loja). Sem confirmação por
/// e-mail por ora — não há envio de campanha ainda; quando houver, o double
/// opt-in nasce junto. Re-inscrição zera `unsubscribedAt` (upsert idempotente).
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  storeId        String
  email          String
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@index([storeId])
}
