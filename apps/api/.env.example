# Copie para .env e preencha. A API RECUSA subir se faltar qualquer variável
# obrigatória — é intencional: melhor falhar no boot que às 3h da manhã com undefined.

NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# ── Banco ────────────────────────────────────────────────────────────────────
# O Postgres vive na VPS e NÃO é exposto na internet (a 5432 está fechada no UFW
# e o pg_hba só aceita loopback). O acesso é por túnel SSH:
#
#     .\scripts\db-tunnel.ps1      ← deixe rodando antes de `pnpm dev`
#
# 5433 local para não colidir com um Postgres instalado na máquina, e para não
# haver dúvida sobre em qual banco você está mexendo.
#
# A senha vai URL-encoded: o "@" separa userinfo de host numa URL, então sem
# %40 o parser lê o resto da senha como hostname.
DATABASE_URL=postgresql://artenojardim:%40SENHA%21@127.0.0.1:5433/artenojardim?schema=public&connection_limit=5

# Banco descartável do `migrate dev` (só desenvolvimento). Pré-criado e de posse
# do role, para não precisar dar CREATEDB à aplicação num servidor compartilhado.
SHADOW_DATABASE_URL=postgresql://artenojardim:%40SENHA%21@127.0.0.1:5433/artenojardim_shadow?schema=public

# ── Loja única ───────────────────────────────────────────────────────────────
# Preenchido pelo `pnpm db:seed`, que imprime o id gerado.
# Na Fase 4 esta variável some: o tenant passa a ser resolvido pelo Host.
STORE_ID=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Segredos DISTINTOS e fortes. Gere com: openssl rand -base64 48
# Staff e cliente têm segredos diferentes: vazar um não vaza o outro.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_CUSTOMER_ACCESS_SECRET=
JWT_CUSTOMER_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=localhost

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowlist explícita. Nunca "*" com credentials.
STORE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── Storage ──────────────────────────────────────────────────────────────────
# local = disco em ./uploads, sem credencial nenhuma (desenvolvimento)
# r2    = Cloudflare R2 (produção)
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./uploads
# Obrigatórias apenas quando STORAGE_DRIVER=r2:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Pagamentos (Stripe) ──────────────────────────────────────────────────────
# STRIPE_PUBLIC (publishable) e STRIPE_SECRET vêm do dashboard do Stripe.
# STRIPE_WEBHOOK_SECRET só existe depois de registrar o endpoint:
#   dev  → `stripe listen --forward-to localhost:4000/api/v1/webhooks/stripe`
#   prod → dashboard, endpoint https://api.artenojardim.com.br/api/v1/webhooks/stripe
STRIPE_PUBLIC=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Integrações (Fase 1 — ainda não usadas) ──────────────────────────────────
# MELHOR_ENVIO_TOKEN=
# MELHOR_ENVIO_SANDBOX=true
# RABBITMQ_URL=amqp://localhost:5672
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
