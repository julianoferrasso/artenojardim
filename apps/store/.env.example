# Loopback: o Server Component fala com a API sem TLS, sem DNS, sem sair da máquina.
INTERNAL_API_URL=http://127.0.0.1:4000

# O browser precisa do domínio público — 127.0.0.1 seria a máquina do cliente.
NEXT_PUBLIC_API_URL=http://localhost:4000

